# Database
SPRING_DATASOURCE_URL=jdbc:postgresql://localhost:5432/skillsync
SPRING_DATASOURCE_USERNAME=skillsync_user
SPRING_DATASOURCE_PASSWORD=your_db_password_here

# JWT Security
APP_JWT_SECRET=your_base64_jwt_secret_here
APP_JWT_EXPIRATION=86400000

# Optional: activate a specific profile
# SPRING_PROFILES_ACTIVE=dev
